{
  "discord": {
    "token": ""
  },
  "bot": {
    "env": "",
    "namePrefix": "",
    "commandPrefix": "",
    // NOTE:
    // only use one:
    "whitelist": [],
    // OR
    "blacklist": []
  },
  "database": {
    "name": "",
    "user": "",
    "password": "",
    "host": "",
    "dialect": "",
    "storage": ""
  },
  "commands": {
    "didAThing": [
      {
        "name": "(name we call it)",
        "role": "(name of role in Discord)",
        "color": "#RGBCOL"
      }
    ]
  },
  "workers": {
    "reactionRoles": [
      {
        "emojiName": "🤷",
        "threshold": 4, // how many reactions are needed to trigger
        "roleName": "(name of role in Discord)",
        "color": "#RGBCOL",
        "forwardChannel": "(optional) channel name to forward the message to on grant"
      }
    ],
    "combinedReactionRoles": [
      {
        "emojiNames": ["TheBest", "TheWorst"], // all must hit threshold
        "threshold": 4,
        "roleName": "(name of role in Discord)",
        "color": "#RGBCOL",
        "forwardChannel": "(optional) channel name to forward the message to on grant"
      }
    ]
  }
}
